# 币安 API 配置
API_KEY=your api key
API_SECRET=your api secret

# 跟踪交易员 ID
TOP_TRADER_ID= want to follow trader id

# 网络代理配置（不使用代理则留空）
PROXY_PORT=7890

# 资金与风控配置
# 用于跟单的总分配本金（单位：USDT）
MY_TOTAL_CAPITAL= 100

# 单笔订单的最大名义价值上限（单位：USDT）
# 风控限额。如果按比例计算出的下单金额超过此值，系统会自动将订单金额拦截并缩减至该最大值，防止单仓风险过大。
MAX_USDT_PER_ORDER= 50.0

# 单笔订单的最小目标价值（单位：USDT）
# 币安合约通常有单笔订单名义价值不低于5U~10U的硬性限制。此处设置你的期望最小下单额。
MIN_USDT_PER_ORDER= 10.0

# 强制兜底最低下单额开关（可选：True / False）
# 当按比例计算出的下单金额小于 MIN_USDT_PER_ORDER 时：
# True：强制将下单金额提升至设定值（如10U）进行保底开仓，确保不错过信号。
# False：直接放弃该笔信号，不开仓。
FORCE_MIN_ORDER=True

# 监控轮询间隔时间（单位：秒）
POLL_INTERVAL=10

# 网页凭证（运行后由程序自动更新填充，亦可手动粘贴）
BINANCE_COOKIE=
BINANCE_CSRFTOKEN=
